# Example environment variables. Do NOT store secrets in the repository.
# Copy this file to `.env` locally and fill with real values.

# Frontend settings
VITE_API_URL=http://localhost:5001/api/v1

# Backend runtime environment
NODE_ENV=development
PORT=5001

# Backend database configuration
DB_DIALECT=postgres
DB_HOST=your-supabase-db-host.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password

# JWT and server settings
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=8h
# You can specify multiple origins separated by commas:
# CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173

# Supabase service credentials (backend only)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=documents
